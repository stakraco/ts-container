{
  "name": "@stakra/ts-container",
  "version": "2.0.1",
  "description": "NestJS-style dependency injection for React and client-side applications. Decorators, container, injector, scanner, module system, application bootstrap, and React bindings — built from scratch, no Inversify.",
  "keywords": [
    "dependency-injection",
    "di",
    "container",
    "nestjs",
    "decorators",
    "injectable",
    "inject",
    "module",
    "ioc",
    "typescript",
    "react",
    "hooks",
    "application",
    "bootstrap"
  ],
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": {
    "name": "Stakra",
    "url": "https://github.com/stakraco"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stakraco/ts-container.git"
  },
  "homepage": "https://github.com/stakraco/ts-container#readme",
  "bugs": {
    "url": "https://github.com/stakraco/ts-container/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@vivtel/metadata": "^1.0.5",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.4",
    "eslint": "10.2.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
